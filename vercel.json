{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/backend.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/confirm-email.html",
      "dest": "/confirm-email.html"
    },
    {
      "src": "/reset-password.html",
      "dest": "/reset-password.html"
    },
    {
      "src": "/api/backend",
      "dest": "/api/backend.js"
    },
    {
      "src": "/termos-de-uso.pdf",
      "dest": "/public/termos-de-uso.pdf"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
